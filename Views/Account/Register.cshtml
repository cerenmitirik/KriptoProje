@{
    ViewData["Title"] = "Kullanıcı Kaydı";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 mb-5">
            <div class="card shadow-xl border-0 auth-card">
                <div class="card-header text-center py-4">
                    <h3 class="fw-bold my-2" style="color: #1e293b;">Yeni Hesap Oluştur</h3>
                    <small class="text-muted">Verileriniz SHA-256 ile şifrelenerek saklanır.</small>
                </div>
                <div class="card-body p-4 pt-2">

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <ul class="mb-0">
                                @foreach (var modelError in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li><i class="bi bi-exclamation-circle-fill me-2"></i>@modelError.ErrorMessage</li>
                                }
                            </ul>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form id="authForm" asp-action="Register" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Kullanıcı Adı</label>
                            <input class="form-control" name="username" type="text" placeholder="Kullanıcı adınızı giriniz" required />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">E-posta Adresi</label>
                            <input class="form-control" name="email" type="email" placeholder="isim@ornek.com" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Şifre</label>
                            <div class="input-group">
                                <input class="form-control" id="passwordInput" name="password" type="password" placeholder="Güçlü bir şifre seçin" required />
                                <button class="btn btn-outline-secondary" type="button" id="togglePasswordBtn">
                                    <i class="bi bi-eye" id="togglePasswordIcon"></i>
                                </button>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" id="submitBtn" class="btn btn-primary shadow-sm py-2">
                                <i class="bi bi-person-plus"></i> Kaydı Tamamla
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const togglePasswordBtn = document.getElementById('togglePasswordBtn');
            const passwordInput = document.getElementById('passwordInput');
            const togglePasswordIcon = document.getElementById('togglePasswordIcon');

            if (togglePasswordBtn) {
                togglePasswordBtn.addEventListener('click', function () {
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);
                    togglePasswordIcon.classList.toggle('bi-eye');
                    togglePasswordIcon.classList.toggle('bi-eye-slash');
                });
            }

            const authForm = document.getElementById('authForm');
            const submitBtn = document.getElementById('submitBtn');

            if (authForm) {
                authForm.addEventListener('submit', function () {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> İşleniyor...';
                });
            }
        });
    </script>
}