@model KriptoProje.Models.User
@{
    ViewData["Title"] = "Güvenli Kasa";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 mb-5">
            <div class="card shadow-xl border-0 auth-card">
                <div class="card-header text-center py-4 bg-dark text-white">
                    <h3 class="fw-bold my-2"><i class="bi bi-shield-lock"></i> Güvenli Veri Kasası</h3>
                    <p class="small text-light">Hassas verileriniz Regex motoru ile çift taraflı doğrulanır.</p>
                </div>
                <div class="card-body p-4">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger shadow-sm">
                            <h6 class="fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Doğrulama Hataları:</h6>
                            <div asp-validation-summary="All" class="small"></div>
                        </div>
                    }

                    @* Formun tamamına ve tek tek inputlara autocomplete="off" ekledik *@
                    <form id="vaultForm" asp-action="UpdateVault" method="post" autocomplete="off">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">T.C. Kimlik No</label>
                                <input name="tcNo" value="@Model?.TcNo" class="form-control" id="tcInput" placeholder="11 haneli rakam" autocomplete="off" />
                                <div class="invalid-feedback">Lütfen 11 haneli geçerli bir TC giriniz.</div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Telefon Numarası</label>
                                <input name="phoneNumber" value="@Model?.PhoneNumber" class="form-control" id="phoneInput" placeholder="05XXXXXXXXX" autocomplete="off" />
                                <div class="invalid-feedback">Telefon 05 ile başlamalı ve 11 hane olmalıdır.</div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">IBAN</label>
                                <input name="iban" value="@Model?.Iban" class="form-control" id="ibanInput" placeholder="TR..." autocomplete="off" />
                                <div class="invalid-feedback">Geçersiz IBAN formatı! TR ile başlamalı ve 24 rakamdan oluşmalı.</div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Kredi Kartı No</label>
                                <input name="creditCard" value="@Model?.CreditCard" class="form-control" id="cardInput" placeholder="16 haneli rakam" autocomplete="off" />
                                <div class="invalid-feedback">Kredi kartı 16 hane olmalıdır.</div>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">IPv4 Adresi</label>
                                <input name="ipAddress" value="@Model?.IpAddress" class="form-control" id="ipInput" placeholder="192.168.1.1" autocomplete="off" />
                                <div class="invalid-feedback">Geçersiz IP adresi formatı!</div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" id="vaultSubmitBtn" class="btn btn-primary shadow-sm py-2">
                                <i class="bi bi-cloud-arrow-up"></i> Verileri Doğrula ve Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const patterns = {
                tc: /^[1-9][0-9]{10}$/,
                phone: /^05[0-9]{9}$/,
                iban: /^TR[0-9]{24}$/,
                card: /^[0-9]{16}$/,
                ip: /^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$/
            };

            const validateInput = (inputSelector, pattern) => {
                const input = document.querySelector(inputSelector);
                if (!input) return;
                
                input.addEventListener('input', function() {
                    if (pattern.test(this.value)) {
                        this.classList.remove('is-invalid');
                        this.classList.add('is-valid');
                    } else {
                        this.classList.remove('is-valid');
                        this.classList.add('is-invalid');
                    }
                });
            };

            // Anlık kontrolleri başlat
            validateInput('#tcInput', patterns.tc);
            validateInput('#phoneInput', patterns.phone);
            validateInput('#ibanInput', patterns.iban);
            validateInput('#cardInput', patterns.card);
            validateInput('#ipInput', patterns.ip);

            // Form gönderilirken buton spinner
            const vaultForm = document.getElementById('vaultForm');
            const submitBtn = document.getElementById('vaultSubmitBtn');

            if (vaultForm) {
                vaultForm.addEventListener('submit', function () {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> İşleniyor...';
                });
            }
        });
    </script>
}